      manager.raiseSalary(7);
      System.out.println("Salary w/ Raise: " + manager.getSalary());
      manager.setBonus(3000);
      System.out.println("Salary w/ Bonus: " + manager.getSalary());
      System.out.println("Hire Day: " + manager.getHireDay());
      
