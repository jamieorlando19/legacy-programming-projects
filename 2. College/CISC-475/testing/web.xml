<?xml version="1.0" encoding="ISO-8859-1"?>

<!DOCTYPE web-app
    PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.2//EN"
    "http://java.sun.com/j2ee/dtds/web-app_2.2.dtd">

<web-app>
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <servlet>
    <servlet-name>
      requestupload
    </servlet-name>
    <servlet-class>
      UploadServlet
    </servlet-class>
    <init-param>
      <param-name>
        uploadDir
      </param-name>
      <param-value>
        /usr/resin-2.1.8/webapps/testing/uploads
      </param-value>
    </init-param>
  </servlet>
</web-app>
